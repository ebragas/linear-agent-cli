{
  "name": "@ebragas/linear-cli",
  "version": "0.7.0",
  "description": "CLI tool for AI agents to interact with Linear using per-agent OAuth identity",
  "bin": {
    "linear": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:integration": "sh -c 'set -a && . ./.env.integration && vitest run src/__tests__/integration/'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebragas/linear-agent-cli.git"
  },
  "keywords": [
    "linear",
    "cli",
    "agent",
    "ai",
    "oauth"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@linear/sdk": "^75.0.0",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.4",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.13.4",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
